<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | CreatorOS</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --cream: #f0ebe0;
            --cream-dark: #e5dece;
            --black: #0e0e0e;
            --teal: #00c9a7;
            --yellow: #f5c842;
            --blue: #4da6ff;
            --red: #ff4c4c;
            --border: 2.5px solid #0e0e0e;
            --shadow: 5px 5px 0px #0e0e0e;
            --shadow-lg: 8px 8px 0px #0e0e0e;
            --shadow-xl: 12px 12px 0px #0e0e0e;
            --radius: 16px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Syne', sans-serif;
            background-color: var(--cream);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            position: relative;
            padding: 40px 16px;
            perspective: 1200px;
        }

        /* ── Grid background ── */
        body::before {
            content: '';
            position: fixed; inset: 0;
            background-image:
                linear-gradient(rgba(14,14,14,0.06) 1px, transparent 1px),
                linear-gradient(90deg, rgba(14,14,14,0.06) 1px, transparent 1px);
            background-size: 44px 44px;
            pointer-events: none; z-index: 0;
        }

        /* ── Floating 3D Shapes ── */
        .shape { position: fixed; pointer-events: none; z-index: 1; transform-style: preserve-3d; }

        .shape-cube { width: 80px; height: 80px; top: 10%; left: 7%; animation: floatCube 7s ease-in-out infinite; }
        .shape-cube .face {
            position: absolute; width: 80px; height: 80px;
            border: var(--border);
            display: flex; align-items: center; justify-content: center;
            font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; color: var(--black);
        }
        .face-front  { background: var(--yellow); transform: translateZ(40px); }
        .face-back   { background: var(--teal);   transform: rotateY(180deg) translateZ(40px); }
        .face-left   { background: var(--cream);  transform: rotateY(-90deg) translateZ(40px); }
        .face-right  { background: var(--blue);   transform: rotateY(90deg) translateZ(40px); }
        .face-top    { background: var(--cream-dark); transform: rotateX(90deg) translateZ(40px); }
        .face-bottom { background: var(--cream-dark); transform: rotateX(-90deg) translateZ(40px); }
        @keyframes floatCube {
            0%,100% { transform: translateY(0) rotateX(15deg) rotateY(0deg) rotateZ(-5deg); }
            33%     { transform: translateY(-22px) rotateX(30deg) rotateY(120deg) rotateZ(-10deg); }
            66%     { transform: translateY(-10px) rotateX(20deg) rotateY(240deg) rotateZ(0deg); }
        }

        .shape-ring {
            width: 110px; height: 110px; top: 15%; right: 6%;
            border: 8px solid var(--black); border-radius: 50%; background: transparent;
            animation: floatRing 9s ease-in-out infinite;
        }
        .shape-ring::after {
            content: ''; position: absolute; inset: 10px;
            border: 4px solid var(--yellow); border-radius: 50%;
        }
        @keyframes floatRing {
            0%,100% { transform: translateY(0) rotateX(55deg) rotateZ(0deg); }
            50%     { transform: translateY(-28px) rotateX(65deg) rotateZ(180deg); }
        }

        .shape-pill {
            bottom: 20%; left: 4%; width: 55px; height: 130px;
            background: var(--teal); border: var(--border);
            border-radius: 999px; box-shadow: var(--shadow);
            animation: floatPill 6s ease-in-out infinite;
        }
        @keyframes floatPill {
            0%,100% { transform: translateY(0) rotateZ(10deg) rotateX(15deg); }
            50%     { transform: translateY(-22px) rotateZ(-10deg) rotateX(25deg); }
        }

        .shape-star { bottom: 10%; right: 8%; width: 65px; height: 65px; animation: floatStar 8s ease-in-out infinite; }
        .shape-star svg { width: 100%; height: 100%; }
        @keyframes floatStar {
            0%,100% { transform: translateY(0) rotate(0deg); }
            50%     { transform: translateY(-16px) rotate(180deg); }
        }

        .shape-triangle {
            top: 60%; right: 4%; width: 0; height: 0;
            border-left: 35px solid transparent; border-right: 35px solid transparent;
            border-bottom: 60px solid var(--blue);
            filter: drop-shadow(3px 3px 0 var(--black));
            animation: floatTriangle 7s ease-in-out infinite;
        }
        @keyframes floatTriangle {
            0%,100% { transform: translateY(0) rotate(0deg); }
            50%     { transform: translateY(-20px) rotate(15deg); }
        }

        /* ── Custom Cursor ── */
        * { cursor: none !important; }

        #cursor-outer {
            position: fixed; width: 36px; height: 36px;
            border: 2.5px solid var(--black); border-radius: 50%;
            pointer-events: none; z-index: 9999;
            transform: translate(-50%, -50%);
            transition: width .25s, height .25s, border-color .25s, background .25s, border-radius .25s;
            mix-blend-mode: multiply;
        }
        #cursor-dot {
            position: fixed; width: 8px; height: 8px;
            background: var(--teal); border-radius: 50%;
            pointer-events: none; z-index: 10000;
            transform: translate(-50%, -50%);
            transition: width .15s, height .15s, background .15s;
        }
        body.cursor-link  #cursor-outer { width: 56px; height: 56px; background: rgba(0,201,167,.12); border-color: var(--teal); border-radius: 12px; }
        body.cursor-link  #cursor-dot   { width: 4px; height: 4px; }
        body.cursor-input #cursor-outer { width: 4px; height: 28px; border-radius: 2px; border-color: var(--teal); background: var(--teal); }
        body.cursor-input #cursor-dot   { opacity: 0; }
        body.cursor-btn   #cursor-outer { width: 70px; height: 70px; background: rgba(245,200,66,.15); border-color: var(--yellow); border-radius: 999px; }
        body.cursor-btn   #cursor-dot   { background: var(--yellow); width: 6px; height: 6px; }
        body.cursor-google #cursor-outer { width: 64px; height: 64px; background: rgba(66,133,244,.12); border-color: #4285F4; border-radius: 999px; }
        body.cursor-google #cursor-dot  { background: #4285F4; }

        .trail-dot {
            position: fixed; border-radius: 50%; pointer-events: none; z-index: 9998;
            transform: translate(-50%,-50%); animation: trailFade .55s ease forwards;
        }
        @keyframes trailFade {
            0%   { opacity: .65; transform: translate(-50%,-50%) scale(1); }
            100% { opacity: 0;   transform: translate(-50%,-50%) scale(.1); }
        }

        #spotlight {
            position: fixed; width: 420px; height: 420px; border-radius: 50%;
            background: radial-gradient(circle, rgba(0,201,167,.07) 0%, transparent 68%);
            pointer-events: none; z-index: 2; transform: translate(-50%,-50%);
        }

        .click-ripple {
            position: fixed; width: 0; height: 0; border-radius: 50%;
            border: 2px solid var(--teal); pointer-events: none; z-index: 9997;
            transform: translate(-50%,-50%); animation: clickRipple .55s ease-out forwards;
        }
        @keyframes clickRipple {
            0%   { width: 0; height: 0; opacity: 1; }
            100% { width: 90px; height: 90px; opacity: 0; }
        }

        #cursor-label {
            position: fixed; pointer-events: none; z-index: 10001;
            font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700;
            color: var(--black); background: var(--yellow);
            border: 1.5px solid var(--black); border-radius: 999px;
            padding: 3px 8px; white-space: nowrap; opacity: 0;
            transform: translate(18px, -28px); transition: opacity .2s;
        }

        /* ── NAVBAR ── */
        .navbar {
            position: fixed; top: 20px; left: 50%; transform: translateX(-50%);
            z-index: 100; background: var(--cream); border: var(--border);
            border-radius: 999px; padding: 10px 20px;
            display: flex; align-items: center; gap: 20px;
            box-shadow: var(--shadow);
            animation: navDrop .6s cubic-bezier(.34,1.56,.64,1) both;
            white-space: nowrap;
        }
        @keyframes navDrop {
            from { transform: translateX(-50%) translateY(-60px); opacity: 0; }
            to   { transform: translateX(-50%) translateY(0); opacity: 1; }
        }
        .nav-brand {
            display: flex; align-items: center; gap: 8px;
            font-weight: 800; font-size: 15px;
            color: var(--black); text-decoration: none;
        }
        .nav-icon {
            width: 28px; height: 28px; background: var(--teal);
            border: 2px solid var(--black); border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-family: 'Syne', sans-serif; font-weight: 800; font-size: 14px;
        }
        .nav-dot { font-family: 'Space Mono', monospace; font-size: 11px; color: #888; }

        /* ── MAIN CARD ── */
        .scene { position: relative; z-index: 10; perspective: 1000px; margin-top: 60px; }

        .card-3d-wrapper {
            transform-style: preserve-3d;
            animation: cardEntrance 1s cubic-bezier(.34,1.56,.64,1) .15s both;
            transition: transform .15s ease;
        }
        @keyframes cardEntrance {
            from { transform: translateY(80px) rotateX(25deg) rotateY(8deg) scale(.85); opacity: 0; }
            to   { transform: translateY(0) rotateX(0) rotateY(0) scale(1); opacity: 1; }
        }

        .card {
            width: min(480px, 100%);
            background: var(--cream); border: var(--border);
            border-radius: var(--radius); box-shadow: var(--shadow-xl);
            position: relative; overflow: visible;
        }
        .card::before {
            content: ''; position: absolute; top: -10px; right: -10px;
            width: 100%; height: 100%; background: var(--black);
            border-radius: var(--radius); z-index: -1; transition: transform .3s;
        }
        .card:hover::before { transform: translate(4px,4px); }

        .badge {
            position: absolute; top: -18px; left: 24px;
            background: var(--teal); border: var(--border); border-radius: 999px;
            padding: 5px 14px; font-family: 'Space Mono', monospace;
            font-size: 11px; font-weight: 700; letter-spacing: .5px;
            box-shadow: 3px 3px 0 var(--black);
            animation: badgeBounce 2s ease-in-out 1.2s infinite; z-index: 20;
        }
        @keyframes badgeBounce {
            0%,100% { transform: translateY(0) rotate(2deg); }
            50%     { transform: translateY(-5px) rotate(-2deg); }
        }

        /* ── Card Header ── */
        .card-header {
            padding: 36px 40px 28px;
            border-bottom: var(--border);
            background: var(--black);
            border-radius: calc(var(--radius) - 1px) calc(var(--radius) - 1px) 0 0;
            position: relative; overflow: hidden;
        }
        .card-header::before {
            content: ''; position: absolute; inset: 0;
            background: repeating-linear-gradient(-45deg, transparent, transparent 8px, rgba(255,255,255,.03) 8px, rgba(255,255,255,.03) 16px);
        }
        .logo-row { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; position: relative; z-index: 1; }
        .logo-icon {
            width: 44px; height: 44px; background: var(--yellow);
            border: 2.5px solid rgba(255,255,255,.2); border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-family: 'Syne', sans-serif; font-weight: 800; font-size: 18px; color: var(--black);
            animation: iconSpin 6s ease-in-out infinite;
            box-shadow: 0 0 20px rgba(245,200,66,.4);
        }
        @keyframes iconSpin {
            0%,100% { transform: rotateY(0deg); }
            50%     { transform: rotateY(360deg); }
        }
        .logo-text { font-family: 'DM Serif Display', serif; font-size: 22px; color: #fff; line-height: 1; }
        .logo-sub  { font-family: 'Space Mono', monospace; font-size: 9px; color: rgba(255,255,255,.4); letter-spacing: 2px; text-transform: uppercase; margin-top: 3px; }

        .header-title { font-family: 'DM Serif Display', serif; font-size: 32px; color: #fff; line-height: 1.1; position: relative; z-index: 1; }
        .header-title em { font-style: italic; color: var(--yellow); }
        .header-sub { font-family: 'Space Mono', monospace; font-size: 11px; color: rgba(255,255,255,.45); margin-top: 8px; line-height: 1.6; position: relative; z-index: 1; }
        .header-bar {
            height: 3px;
            background: linear-gradient(90deg, var(--yellow), var(--teal), var(--blue), var(--yellow));
            background-size: 200% 100%; animation: barSlide 2s linear infinite;
            border-radius: 999px; margin-top: 18px; position: relative; z-index: 1;
        }
        @keyframes barSlide { 0% { background-position: 0% 0%; } 100% { background-position: 200% 0%; } }

        /* ── Card Body ── */
        .card-body { padding: 32px 40px 36px; }

        .error-banner {
            background: #fff0f0; border: 2px solid var(--red); border-radius: 10px;
            padding: 12px 16px; font-family: 'Space Mono', monospace; font-size: 12px;
            color: var(--red); margin-bottom: 20px;
            display: flex; align-items: center; gap: 8px;
            box-shadow: 3px 3px 0 var(--red);
        }
        .error-banner::before { content: '✕'; font-weight: 700; }

        /* ── Google Button ── */
        .google-btn {
            width: 100%; padding: 13px 20px;
            background: #fff; border: var(--border); border-radius: 12px;
            display: flex; align-items: center; justify-content: center; gap: 12px;
            font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700;
            color: var(--black); text-decoration: none;
            box-shadow: var(--shadow); position: relative; overflow: hidden;
            transition: transform .15s ease, filter .15s;
        }
        .google-btn::before {
            content: ''; position: absolute; top: 0; left: -100%;
            width: 60%; height: 100%;
            background: rgba(66,133,244,.08); transform: skewX(-20deg);
            transition: left .4s ease;
        }
        .google-btn:hover::before { left: 140%; }
        .google-btn:hover { filter: brightness(1.03); }
        .google-btn-shadow { position: absolute; inset: 0; background: var(--black); border-radius: 12px; transform: translate(5px,5px); z-index: -1; transition: transform .15s; }
        .google-wrap { position: relative; }
        .google-wrap:hover .google-btn-shadow { transform: translate(7px,7px); }
        .google-wrap:active .google-btn { transform: translate(3px,3px); }
        .google-wrap:active .google-btn-shadow { transform: translate(2px,2px); }
        .google-icon { width: 20px; height: 20px; flex-shrink: 0; }

        /* ── Divider ── */
        .divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1.5px; background: var(--black); opacity: .15; }
        .divider span { font-family: 'Space Mono', monospace; font-size: 11px; color: #999; }

        /* ── Fields ── */
        .fields { display: flex; flex-direction: column; gap: 16px; }
        .field-group { display: flex; flex-direction: column; gap: 6px; }
        .field-label {
            font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700;
            letter-spacing: 1px; text-transform: uppercase; color: var(--black);
            display: inline-block; transition: transform .3s, color .3s;
        }
        .field-wrap { position: relative; transform-style: preserve-3d; transition: transform .2s; }
        .field-wrap:focus-within { transform: translateY(-3px) rotateX(2deg); }
        .field-shadow {
            position: absolute; inset: 0; background: var(--black);
            border-radius: 10px; transform: translate(4px,4px); transition: transform .2s; z-index: 0;
        }
        .field-wrap:focus-within .field-shadow { transform: translate(6px,6px); }
        .field-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 16px; z-index: 2; pointer-events: none; }

        input[type="email"],
        input[type="password"] {
            width: 100%; padding: 13px 16px 13px 42px;
            border: var(--border); border-radius: 10px;
            background: #fff; color: var(--black);
            font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 600;
            outline: none; position: relative; z-index: 1;
            transition: box-shadow .2s, background .2s;
        }
        input::placeholder { color: #aaa; font-weight: 400; }
        input:focus { background: #fffdf5; box-shadow: 0 0 0 3px rgba(0,201,167,.2); }

        .pw-toggle {
            position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
            z-index: 2; background: none; border: none; font-size: 16px; color: #888;
            transition: color .2s;
        }
        .pw-toggle:hover { color: var(--black); }

        /* ── Primary Button ── */
        .btn-wrap { position: relative; transform-style: preserve-3d; margin-top: 4px; }
        .btn-shadow { position: absolute; inset: 0; background: var(--black); border-radius: 12px; transform: translate(5px,5px); transition: transform .15s; }

        .btn {
            width: 100%; padding: 15px; border: var(--border); border-radius: 12px;
            background: var(--teal); color: var(--black);
            font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 800;
            cursor: pointer; position: relative; z-index: 1;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            transition: transform .15s, filter .15s; overflow: hidden;
        }
        .btn::before {
            content: ''; position: absolute; top: 0; left: -100%;
            width: 60%; height: 100%; background: rgba(255,255,255,.2);
            transform: skewX(-20deg); transition: left .4s;
        }
        .btn:hover::before { left: 140%; }
        .btn:hover { filter: brightness(1.05); }
        .btn:hover ~ .btn-shadow { transform: translate(7px,7px); }
        .btn:active { transform: translate(3px,3px) !important; }
        .btn:active ~ .btn-shadow { transform: translate(2px,2px); }
        .btn-arrow { display: inline-block; transition: transform .3s; }
        .btn:hover .btn-arrow { transform: translateX(5px); }
        .btn.loading { background: var(--cream-dark); cursor: wait; }

        /* ── Contributor Button ── */
        .contrib-wrap { position: relative; margin-top: 12px; }
        .contrib-shadow { position: absolute; inset: 0; background: var(--black); border-radius: 12px; transform: translate(4px,4px); transition: transform .15s; }
        .btn-contrib {
            width: 100%; padding: 13px; border: var(--border); border-radius: 12px;
            background: var(--cream); color: var(--black);
            font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700;
            cursor: pointer; position: relative; z-index: 1;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            transition: transform .15s, background .2s; overflow: hidden;
        }
        .btn-contrib:hover { background: var(--cream-dark); }
        .btn-contrib:hover ~ .contrib-shadow { transform: translate(6px,6px); }
        .btn-contrib:active { transform: translate(2px,2px) !important; }
        .btn-contrib:active ~ .contrib-shadow { transform: translate(2px,2px); }

        .spinner { width: 18px; height: 18px; border: 3px solid rgba(0,0,0,.15); border-top-color: var(--black); border-radius: 50%; animation: spin .7s linear infinite; display: none; }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Footer ── */
        .switch-link {
            text-align: center; margin-top: 24px; padding-top: 24px;
            border-top: 1.5px dashed rgba(14,14,14,.15);
            font-size: 13px; color: #666;
        }
        .switch-link a {
            color: var(--black); font-weight: 800; text-decoration: none;
            border-bottom: 2px solid var(--teal); padding-bottom: 1px; transition: background .2s;
        }
        .switch-link a:hover { background: rgba(0,201,167,.12); }

        /* ── Ticker ── */
        .ticker {
            position: absolute; bottom: -18px; right: 24px;
            background: var(--black); color: #fff;
            border: var(--border); border-color: rgba(255,255,255,.1);
            border-radius: 10px; padding: 8px 14px;
            display: flex; align-items: center; gap: 10px;
            font-family: 'Space Mono', monospace; font-size: 11px;
            box-shadow: 3px 3px 0 var(--yellow);
            animation: tickerSlide .6s cubic-bezier(.34,1.56,.64,1) 1.4s both; z-index: 20;
        }
        @keyframes tickerSlide {
            from { transform: translateY(20px); opacity: 0; }
            to   { transform: translateY(0); opacity: 1; }
        }
        .ticker-dot { width: 8px; height: 8px; background: var(--yellow); border-radius: 50%; animation: pulse 1.5s ease-in-out infinite; }
        @keyframes pulse { 0%,100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.4); opacity: .6; } }
        .ticker-count { color: var(--yellow); font-weight: 700; }

        /* ── Shake ── */
        @keyframes shake {
            0%,100% { transform: translateX(0); }
            20% { transform: translateX(-6px); } 40% { transform: translateX(6px); }
            60% { transform: translateX(-4px); } 80% { transform: translateX(4px); }
        }

        @media (max-width: 520px) {
            .card-header { padding: 28px 24px 22px; }
            .card-body   { padding: 24px 24px 28px; }
            .header-title { font-size: 26px; }
            .shape-triangle { display: none; }
        }
    </style>
</head>
<body>
    <main class="auth-shell">
        <section class="auth-card">
            <a class="brand" href="/">
                <span class="brand-mark">C</span>
                <span>CreatorOS</span>
            </a>

            <h1>Welcome back</h1>
            <p class="subtitle">Log in to continue managing your creator tools and shortened links.</p>

            <% if (typeof error !== 'undefined' && error) { %>
                <p class="auth-error" role="alert"><%= error %></p>
            <% } %>

            <a
                class="google-login"
                href="/auth/google"
                data-loading-text="Connecting..."
            >
                <svg class="google-icon" viewBox="0 0 48 48" aria-hidden="true" focusable="false">
                    <path fill="#EA4335" d="M24 9.5c3.5 0 6.5 1.2 8.9 3.5l6.6-6.6C35.5 2.7 30.3.5 24 .5 14.8.5 6.9 5.8 3.1 13.5l7.7 6C12.6 13.6 17.8 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.6 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 2.9-2.2 5.4-4.8 7.1l7.4 5.7c4.3-4 7.3-9.9 7.3-16.8z"/>
                    <path fill="#FBBC05" d="M10.8 28.5c-.5-1.4-.8-2.9-.8-4.5s.3-3.1.8-4.5l-7.7-6C1.5 16.7.6 20.2.6 24s.9 7.3 2.5 10.5l7.7-6z"/>
                    <path fill="#34A853" d="M24 47.5c6.3 0 11.6-2.1 15.4-5.7L32 36.1c-2.1 1.4-4.7 2.2-8 2.2-6.2 0-11.4-4.1-13.2-9.8l-7.7 6C6.9 42.2 14.8 47.5 24 47.5z"/>
                </svg>
                <span>Continue with Google</span>
            </a>

            <div class="divider">or</div>

            <form action="/login" method="POST" id="email-login-form">
                <input type="email" name="email" placeholder="Email" required>
                <input type="password" name="password" placeholder="Password" required>
                <button type="submit" data-loading-text="Logging in...">Login</button>
            </form>

            <form action="/login/contributor" method="POST" class="contributor-form" id="contributor-login-form">
                <button type="submit" class="contributor-btn" data-loading-text="Continuing...">Continue as Contributor</button>
            </form>

            <p class="switch-link">
                Don't have an account?
                <a href="/signup">Signup</a>
            </p>
        </section>
    </main>
    <script>
        const googleLogin = document.querySelector('.google-login');
        const emailForm = document.querySelector('#email-login-form');
        const contributorForm = document.querySelector('#contributor-login-form');

        // ═══════════════════════════════════════════════
        // 5. FORM SUBMITS
        // ═══════════════════════════════════════════════
        document.getElementById('login-form').addEventListener('submit', function () {
            if (loginBtn.classList.contains('loading')) return;
            loginBtn.classList.add('loading');
            document.getElementById('spinner').style.display = 'block';
            document.getElementById('btnText').textContent = 'Logging in...';
            document.getElementById('btnArrow').style.display = 'none';
        });

        document.getElementById('contributor-form').addEventListener('submit', function () {
            if (contribBtn.classList.contains('loading')) return;
            contribBtn.classList.add('loading');
            document.getElementById('contrib-spinner').style.display = 'block';
            document.getElementById('contribText').textContent = 'Connecting...';
        });

        googleBtn.addEventListener('click', function () {
            document.getElementById('google-label').textContent = 'Connecting...';
            this.style.opacity = '0.75';
        });

        // ═══════════════════════════════════════════════
        // 6. SHAKE ON INVALID
        // ═══════════════════════════════════════════════
        document.querySelectorAll('input').forEach(inp => {
            inp.addEventListener('invalid', e => {
                e.preventDefault();
                const wrap = inp.closest('.field-wrap');
                wrap.style.animation = 'none'; void wrap.offsetWidth;
                wrap.style.animation = 'shake 0.4s ease';
                inp.style.borderColor = '#ff4c4c';
                inp.style.boxShadow = '0 0 0 3px rgba(255,76,76,.15)';
                setTimeout(() => { inp.style.borderColor = ''; inp.style.boxShadow = ''; }, 1200);
            });
        });

        contributorForm?.addEventListener('submit', async function (event) {
            event.preventDefault();

            const submitButton = this.querySelector('button[type="submit"]');

            if (submitButton) {
                submitButton.disabled = true;
                submitButton.textContent = submitButton.dataset.loadingText;
            }

            try {
                const response = await fetch('/api/auth/contributor-login', {
                    method: 'POST',
                    headers: {
                        Accept: 'application/json',
                    },
                });
                const data = await response.json();

                if (!response.ok || !data.success) {
                    throw new Error(data.message || 'Contributor login failed');
                }

                localStorage.setItem('token', data.token);
                localStorage.setItem('user', JSON.stringify(data.user));
                window.location.href = '/dashboard';
            } catch (error) {
                console.error(error);

                if (submitButton) {
                    submitButton.disabled = false;
                    submitButton.textContent = 'Continue as Contributor';
                }
            }
        });
    </script>
</body>
</html>