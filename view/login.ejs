<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Titli 🦋</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-gradient: linear-gradient(135deg, #1e3a8a, #3b0764);
            --panel-glass: rgba(255, 255, 255, 0.05);
            --border-glass: rgba(255, 255, 255, 0.1);
            --text-main: #ffffff;
            --text-muted: #94a3b8;
            --accent: #22d3ee;
            --accent-hover: #67e8f9;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg-gradient);
            min-height: 100vh;
            display: grid;
            place-items: center;
            overflow-x: hidden;
            position: relative;
            padding: 40px 16px;
        }

        canvas#bg { position: fixed; inset: 0; z-index: 1; pointer-events: none; }

        .orb { position: fixed; border-radius: 50%; filter: blur(70px); opacity: 0.2; pointer-events: none; z-index: 2; }
        .o1 { width: 300px; height: 300px; background: radial-gradient(circle, #a855f7, transparent 70%); top: -60px; right: -40px; animation: orbFloat1 8s ease-in-out infinite; }
        .o2 { width: 340px; height: 340px; background: radial-gradient(circle, #1e3a8a, transparent 70%); bottom: -80px; left: -60px; opacity: 0.35; animation: orbFloat2 10s ease-in-out infinite; }
        .o3 { width: 180px; height: 180px; background: radial-gradient(circle, #06b6d4, transparent 70%); top: 50%; left: 50%; transform: translate(-50%, -50%); opacity: 0.15; animation: orbFloat3 6s ease-in-out infinite; }

        @keyframes orbFloat1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-20px,25px)} }
        @keyframes orbFloat2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(20px,-20px)} }
        @keyframes orbFloat3 { 0%,100%{transform:translate(-50%,-50%) scale(1)} 50%{transform:translate(-50%,-50%) scale(1.3)} }

        .card {
            position: relative; z-index: 10;
            width: min(460px, 100%);
            padding: 44px 40px;
            background: var(--panel-glass);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid var(--border-glass);
            border-radius: 28px;
            box-shadow: 0 0 0 1px rgba(168,85,247,0.06), 0 30px 60px rgba(0,0,0,0.4);
            color: var(--text-main);
            opacity: 0;
            transform: translateY(32px) scale(0.97);
        }
        .card.visible {
            opacity: 1; transform: translateY(0) scale(1);
            transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1), border-color 0.3s, box-shadow 0.3s;
        }
        .card:hover {
            border-color: rgba(34,211,238,0.25);
            box-shadow: 0 0 0 1px rgba(34,211,238,0.1), 0 0 50px rgba(34,211,238,0.05), 0 30px 60px rgba(0,0,0,0.4);
        }
        .card::before {
            content: '';
            position: absolute; inset: -1px;
            border-radius: 28px;
            padding: 1px;
            background: linear-gradient(135deg, rgba(34,211,238,0.3), rgba(168,85,247,0.3), rgba(34,211,238,0.1));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            opacity: 0;
            transition: opacity 0.4s;
            pointer-events: none;
            background-size: 200% 200%;
            animation: borderShift 4s linear infinite;
        }
        .card:hover::before { opacity: 1; }
        @keyframes borderShift { 0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%} }

        .ftag { position: absolute; font-size: 10px; font-weight: 600; letter-spacing: 1px; padding: 4px 10px; border-radius: 999px; opacity: 0; pointer-events: none; transform: translateY(-8px); }
        .t1 { top: 18px; left: 18px; background: rgba(34,211,238,0.12); color: #22d3ee; border: 1px solid rgba(34,211,238,0.2); }
        .t2 { top: 18px; right: 18px; background: rgba(168,85,247,0.12); color: #c084fc; border: 1px solid rgba(168,85,247,0.2); }

        .logo-wrap { text-align: center; margin-bottom: 26px; }
        .logo { font-size: 26px; font-weight: 800; letter-spacing: 1px; color: var(--text-main); text-decoration: none; display: inline-block; margin-bottom: 8px; position: relative; animation: logoPulse 3s ease-in-out infinite; }
        @keyframes logoPulse { 0%,100%{text-shadow:0 0 10px rgba(34,211,238,0.3)} 50%{text-shadow:0 0 25px rgba(34,211,238,0.7), 0 0 50px rgba(168,85,247,0.4)} }
        .logo::after { content: ''; position: absolute; bottom: -4px; left: 50%; transform: translateX(-50%); width: 40px; height: 2px; background: linear-gradient(90deg, #22d3ee, #a855f7); border-radius: 2px; animation: lineExpand 2s ease-in-out infinite alternate; }
        @keyframes lineExpand { 0%{width:30px;opacity:0.6} 100%{width:60px;opacity:1} }

        .title { font-size: 27px; font-weight: 700; letter-spacing: -0.5px; color: var(--text-main); text-align: center; margin-bottom: 6px; }
        .subtitle { font-size: 13px; color: var(--text-muted); line-height: 1.6; text-align: center; }

        .error-banner { border-left: 4px solid #ef4444; border-radius: 0.5rem; padding: 0.75rem 1rem; color: #fca5a5; background: rgba(239,68,68,0.1); font-size: 0.85rem; margin: 16px 0 0; line-height: 1.4; }

        .google-btn { width: 100%; padding: 13px 22px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.15); background: rgba(255,255,255,0.06); color: var(--text-main); font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 0.75rem; cursor: pointer; text-decoration: none; transition: background 0.3s, border-color 0.3s, transform 0.2s, box-shadow 0.3s; margin-top: 26px; }
        .google-btn:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.3); transform: scale(1.02); box-shadow: 0 8px 20px rgba(0,0,0,0.2); }
        .google-icon { width: 1.2rem; height: 1.2rem; flex-shrink: 0; }

        .divider { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 1rem; margin: 20px 0 0; color: rgba(255,255,255,0.35); font-size: 12px; text-transform: uppercase; letter-spacing: 1px; }
        .divider::before, .divider::after { content: ''; height: 1px; background: rgba(255,255,255,0.1); }

        .fields { display: flex; flex-direction: column; gap: 13px; margin-top: 20px; }

        .field-wrap { position: relative; overflow: hidden; border-radius: 999px; }
        .field-wrap::before { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(34,211,238,0.12), transparent); transform: translateX(-100%); transition: transform 0.4s ease; pointer-events: none; z-index: 2; border-radius: 999px; }
        .field-wrap:focus-within::before { transform: translateX(100%); }

        input { width: 100%; padding: 13px 22px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); color: var(--text-main); font-family: 'Poppins', sans-serif; font-size: 14px; outline: none; transition: border-color 0.3s, box-shadow 0.3s, background 0.3s, transform 0.2s; position: relative; z-index: 1; }
        input::placeholder { color: rgba(255,255,255,0.3); }
        input:focus { border-color: var(--accent); background: rgba(255,255,255,0.08); box-shadow: 0 0 0 3px rgba(34,211,238,0.08), 0 0 20px rgba(34,211,238,0.12); transform: scaleX(1.01); }

        .btn { width: 100%; padding: 14px; border: none; border-radius: 999px; background: linear-gradient(135deg, #22d3ee, #0284c7); color: #041e3a; font-family: 'Poppins', sans-serif; font-size: 15px; font-weight: 700; cursor: pointer; margin-top: 4px; position: relative; overflow: hidden; transition: transform 0.2s, box-shadow 0.3s, filter 0.2s; box-shadow: 0 8px 24px rgba(34,211,238,0.2); }
        .btn::after { content: ''; position: absolute; top: -50%; left: -60%; width: 40%; height: 200%; background: rgba(255,255,255,0.15); transform: skewX(-20deg); transition: left 0.5s ease; pointer-events: none; }
        .btn:hover::after { left: 130%; }
        .btn:hover { box-shadow: 0 14px 36px rgba(34,211,238,0.38); filter: brightness(1.08); }
        .btn:active { transform: translateY(1px) scale(0.99) !important; }
        .btn.loading { opacity: 0.7; cursor: wait; }

        .btn-contributor { background: transparent; border: 1px solid rgba(34,211,238,0.4); color: var(--accent); box-shadow: none; margin-top: 0; }
        .btn-contributor::after { display: none; }
        .btn-contributor:hover { background: rgba(34,211,238,0.08); border-color: var(--accent); color: #fff; box-shadow: 0 0 20px rgba(34,211,238,0.15); filter: none; }

        .switch-link { text-align: center; margin-top: 20px; font-size: 13px; color: #64748b; }
        .switch-link a { color: var(--accent); font-weight: 600; text-decoration: none; margin-left: 4px; position: relative; }
        .switch-link a::after { content: ''; position: absolute; bottom: -1px; left: 0; width: 0; height: 1px; background: var(--accent); transition: width 0.3s; }
        .switch-link a:hover::after { width: 100%; }

        @keyframes ripple { to { width: 300px; height: 300px; opacity: 0; } }
        @keyframes shake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-6px)} 40%{transform:translateX(6px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(4px)} }
    </style>
</head>
<body>

    <canvas id="bg"></canvas>
    <div class="orb o1" id="orb1"></div>
    <div class="orb o2"></div>
    <div class="orb o3"></div>

    <div class="card" id="card">
        <span class="ftag t1" id="t1">SECURE</span>
        <span class="ftag t2" id="t2">FREE</span>

        <div class="logo-wrap">
            <a href="/" class="logo">Titli 🦋</a>
        </div>
        <div class="title">Welcome Back</div>
        <p class="subtitle">Access your beautiful creator ecosystem dashboard.</p>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-banner" role="alert"><%= error %></div>
        <% } %>

        <a class="google-btn" href="/auth/google" id="google-btn">
            <svg class="google-icon" viewBox="0 0 48 48">
                <path fill="#EA4335" d="M24 9.5c3.5 0 6.5 1.2 8.9 3.5l6.6-6.6C35.5 2.7 30.3.5 24 .5 14.8.5 6.9 5.8 3.1 13.5l7.7 6C12.6 13.6 17.8 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.6 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 2.9-2.2 5.4-4.8 7.1l7.4 5.7c4.3-4 7.3-9.9 7.3-16.8z"/>
                <path fill="#FBBC05" d="M10.8 28.5c-.5-1.4-.8-2.9-.8-4.5s.3-3.1.8-4.5l-7.7-6C1.5 16.7.6 20.2.6 24s.9 7.3 2.5 10.5l7.7-6z"/>
                <path fill="#34A853" d="M24 47.5c6.3 0 11.6-2.1 15.4-5.7L32 36.1c-2.1 1.4-4.7 2.2-8 2.2-6.2 0-11.4-4.1-13.2-9.8l-7.7 6C6.9 42.2 14.8 47.5 24 47.5z"/>
            </svg>
            <span id="google-label">Continue with Google</span>
        </a>

        <div class="divider">or</div>

        <form action="/login" method="POST" id="login-form">
            <div class="fields">
                <div class="field-wrap">
                    <input type="email" name="email" id="f1" placeholder="Email Address" required />
                </div>
                <div class="field-wrap">
                    <input type="password" name="password" id="f2" placeholder="Password" required />
                </div>
                <button type="submit" class="btn" id="login-btn" data-loading-text="Logging in...">
                    Login to Dashboard
                </button>
            </div>
        </form>

        <form action="/login/contributor" method="POST" id="contributor-form" style="margin-top: 13px;">
            <button type="submit" class="btn btn-contributor" id="contrib-btn" data-loading-text="Connecting...">
                Login as Contributor
            </button>
        </form>

        <p class="switch-link">Don't have an account? <a href="/signup">Create one here</a></p>
    </div>

    <script>
    (function(){
        const canvas = document.getElementById('bg');
        const ctx = canvas.getContext('2d');
        let W, H, pts = [];
        const mouse = { x: -999, y: -999 };

        function resize() {
            W = canvas.width = window.innerWidth;
            H = canvas.height = window.innerHeight;
            makePts();
        }
        function makePts() {
            pts = [];
            const cols = Math.floor(W/56), rows = Math.floor(H/56);
            for (let r=0;r<=rows;r++) for (let c=0;c<=cols;c++) {
                const ox=c*(W/cols), oy=r*(H/rows);
                pts.push({ox,oy,x:ox,y:oy,vx:0,vy:0,size:Math.random()*1.1+0.4,alpha:Math.random()*0.35+0.08,hue:Math.random()<0.5?'34,211,238':'168,85,247'});
            }
        }
        window.addEventListener('resize', resize); resize();
        document.addEventListener('mousemove', e=>{mouse.x=e.clientX;mouse.y=e.clientY;});
        document.addEventListener('mouseleave',()=>{mouse.x=-999;mouse.y=-999;});

        function loop() {
            ctx.clearRect(0,0,W,H);
            for (let i=0;i<pts.length;i++) for (let j=i+1;j<pts.length;j++) {
                const dx=pts[i].x-pts[j].x, dy=pts[i].y-pts[j].y, d=Math.sqrt(dx*dx+dy*dy);
                if(d<65){ctx.beginPath();ctx.strokeStyle=`rgba(168,85,247,${0.05*(1-d/65)})`;ctx.lineWidth=0.5;ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);ctx.stroke();}
            }
            pts.forEach(p=>{
                const dx=mouse.x-p.x, dy=mouse.y-p.y, d=Math.sqrt(dx*dx+dy*dy);
                const f=d<100?(100-d)/100:0;
                if(f>0){p.vx-=(dx/d)*f*1.1;p.vy-=(dy/d)*f*1.1;}
                p.vx+=(p.ox-p.x)*0.04; p.vy+=(p.oy-p.y)*0.04;
                p.vx*=0.82; p.vy*=0.82; p.x+=p.vx; p.y+=p.vy;
                const md=Math.sqrt((mouse.x-p.x)**2+(mouse.y-p.y)**2);
                const glow=md<120?1-md/120:0;
                ctx.beginPath();ctx.arc(p.x,p.y,p.size+glow*1.6,0,Math.PI*2);
                ctx.fillStyle=`rgba(${p.hue},${p.alpha+glow*0.55})`;ctx.fill();
            });
            requestAnimationFrame(loop);
        }
        loop();

        setTimeout(()=>document.getElementById('card').classList.add('visible'), 80);

        ['f1','f2'].forEach((id,i)=>{
            const el=document.getElementById(id).parentElement;
            el.style.opacity='0'; el.style.transform='translateX(-16px)';
            el.style.transition=`opacity 0.5s ${0.5+i*0.12}s, transform 0.5s ${0.5+i*0.12}s`;
            setTimeout(()=>{el.style.opacity='1';el.style.transform='translateX(0)';},100);
        });

        ['t1','t2'].forEach((id,i)=>{
            const el=document.getElementById(id);
            setTimeout(()=>{el.style.transition='opacity 0.5s, transform 0.5s';el.style.opacity='1';el.style.transform='translateY(0)';},900+i*160);
        });

        document.addEventListener('mousemove',e=>{
            const cx=window.innerWidth/2, cy=window.innerHeight/2;
            document.getElementById('orb1').style.transform=`translate(${(e.clientX-cx)*0.025}px,${(e.clientY-cy)*0.025}px)`;
        });

        const loginBtn=document.getElementById('login-btn');
        loginBtn.addEventListener('mousemove',e=>{
            const r=loginBtn.getBoundingClientRect();
            loginBtn.style.transform=`translate(${(e.clientX-r.left-r.width/2)*0.22}px,${(e.clientY-r.top-r.height/2)*0.22}px) translateY(-3px)`;
        });
        loginBtn.addEventListener('mouseleave',()=>{loginBtn.style.transform='';});

        document.getElementById('login-form').addEventListener('submit',function(){
            if(loginBtn.classList.contains('loading')) return;
            loginBtn.classList.add('loading');
            loginBtn.textContent=loginBtn.dataset.loadingText;
            const span=document.createElement('span');
            span.style.cssText='position:absolute;top:50%;left:50%;width:0;height:0;background:rgba(255,255,255,0.25);border-radius:50%;transform:translate(-50%,-50%);pointer-events:none;animation:ripple 0.6s ease-out forwards';
            loginBtn.appendChild(span);
        });

        document.getElementById('google-btn').addEventListener('click',function(){
            document.getElementById('google-label').textContent='Connecting with Google...';
            this.style.opacity='0.8';
        });

        document.getElementById('contributor-form').addEventListener('submit',function(){
            const btn=document.getElementById('contrib-btn');
            if(btn.classList.contains('loading')) return;
            btn.classList.add('loading');
            btn.textContent=btn.dataset.loadingText;
        });

        document.querySelectorAll('input').forEach(inp=>{
            inp.addEventListener('invalid',e=>{
                e.preventDefault();
                inp.style.animation='none'; void inp.offsetWidth;
                inp.style.animation='shake 0.4s ease';
                inp.style.borderColor='#f87171';
                inp.style.boxShadow='0 0 0 3px rgba(248,113,113,0.12)';
                setTimeout(()=>{inp.style.borderColor='';inp.style.boxShadow='';},1200);
            });
        });
    })();
    </script>
</body>
</html>