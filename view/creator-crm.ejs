<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Creator CRM | CreatorOS</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #06101f;
      --surface: rgba(13, 24, 49, 0.88);
      --border: rgba(148, 163, 184, 0.16);
      --text: #f8fafc;
      --muted: #cbd5e1;
      --accent: #22d3ee;
      --accent-strong: #38bdf8;
      --success: #22c55e;
      --danger: #f87171;
      --shadow: 0 24px 50px rgba(0, 0, 0, 0.26);
      --sidebar-width: 280px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      min-height: 100vh;
      font-family: 'Poppins', sans-serif;
      background:
        radial-gradient(900px 320px at 20% -80px, rgba(34, 211, 238, 0.16), transparent 70%),
        radial-gradient(900px 320px at 80% 0%, rgba(59, 130, 246, 0.14), transparent 70%),
        linear-gradient(180deg, #0b1220, #06101f);
      color: var(--text);
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }
    .dashboard-layout { display: grid; grid-template-columns: var(--sidebar-width) minmax(0,1fr); min-height: 100vh; }
    .sidebar { padding: 2rem 1.2rem; border-right: 1px solid var(--border); background: rgba(6, 16, 31, 0.92); display: flex; flex-direction: column; gap: 1.3rem; }
    .brand { display: flex; align-items: center; gap: 0.85rem; font-size: 1.3rem; font-weight: 800; }
    .brand-mark { width: 2.5rem; height: 2.5rem; border-radius: 1rem; display: grid; place-items: center; background: linear-gradient(135deg, #67e8f9, #22d3ee); color: #042f3e; font-weight: 800; }
    .nav-group { display: grid; gap: 0.65rem; }
    .nav-link { display: block; padding: 0.95rem 1rem; border-radius: 0.85rem; color: var(--muted); font-weight: 600; transition: background 0.2s ease, transform 0.2s ease; }
    .nav-link:hover, .nav-link.active { background: rgba(34, 211, 238, 0.12); color: #fff; transform: translateX(4px); }
    .sidebar-label { color: var(--muted); font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; }
    .main { padding: 1.8rem 2rem; }
    .topbar { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 2rem; }
    .topbar h1 { font-size: clamp(2rem, 2.6vw, 2.6rem); margin-bottom: 0.4rem; }
    .topbar p { color: var(--muted); max-width: 760px; }
    .profile-chip { display: inline-flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: 999px; background: rgba(255,255,255,0.05); }
    .avatar { width: 2.4rem; height: 2.4rem; display: grid; place-items: center; border-radius: 999px; background: linear-gradient(135deg, #67e8f9, #22d3ee); color: #042f3e; font-weight: 800; }
    .cards-grid { display: grid; gap: 1.5rem; grid-template-columns: repeat(12, minmax(0,1fr)); }
    .panel { grid-column: span 8; background: var(--surface); border: 1px solid var(--border); border-radius: 1.4rem; box-shadow: var(--shadow); padding: 1.75rem; }
    .stats-panel { grid-column: span 4; display: grid; gap: 1rem; }
    .panel-head { display: flex; justify-content: space-between; gap: 1rem; align-items: center; margin-bottom: 1rem; }
    .panel-head h2 { margin: 0; font-size: 1.25rem; }
    .badge { display: inline-flex; align-items: center; padding: 0.55rem 0.95rem; border-radius: 999px; background: rgba(34, 211, 238, 0.14); color: #67e8f9; font-weight: 700; font-size: 0.86rem; }
    .form-row { display: grid; gap: 1rem; margin-bottom: 1.25rem; }
    .input, .textarea { width: 100%; border: 1px solid var(--border); border-radius: 1rem; background: rgba(255,255,255,0.04); color: var(--text); padding: 1rem 1.1rem; font: inherit; }
    .textarea { min-height: 150px; resize: vertical; }
    .primary-btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.65rem; padding: 0.95rem 1.35rem; border-radius: 999px; border: none; color: #042f3e; background: linear-gradient(135deg, #67e8f9, #22d3ee); font-weight: 700; cursor: pointer; }
    .info-box, .alert-box { margin-bottom: 1.5rem; padding: 1rem 1.2rem; border-radius: 1rem; border: 1px solid transparent; }
    .info-box { background: rgba(59, 130, 246, 0.08); border-color: rgba(59, 130, 246, 0.18); color: #dbeafe; }
    .alert-box { background: rgba(248, 113, 113, 0.12); border-color: rgba(248, 113, 113, 0.24); color: #fee2e2; }
    .success-box { background: rgba(34, 197, 94, 0.12); border-color: rgba(34, 197, 94, 0.24); color: #d1fae5; }
    .table { width: 100%; border-collapse: collapse; }
    .table th, .table td { padding: 0.95rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .table th { color: var(--muted); text-align: left; font-size: 0.92rem; }
    .status-pill { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.35rem 0.75rem; border-radius: 999px; font-size: 0.82rem; font-weight: 700; }
    .status-pending { background: rgba(59, 130, 246, 0.14); color: #bae6fd; }
    .status-accepted { background: rgba(34, 197, 94, 0.14); color: #dcfce7; }
    .status-expired { background: rgba(248, 113, 113, 0.14); color: #fecaca; }
    @media (max-width: 980px) {
      .dashboard-layout { grid-template-columns: 1fr; }
      .panel { grid-column: span 12; }
      .stats-panel { grid-column: span 12; }
    }
  </style>
</head>
<body>
  <div class="dashboard-layout">
    <aside class="sidebar">
      <a href="/" class="brand">
        <span class="brand-mark">CO</span>
        CreatorOS
      </a>
      <div class="nav-group">
        <div class="sidebar-label">Services</div>
        <a class="nav-link" href="/services/creator-crm">Creator CRM</a>
        <a class="nav-link" href="/services/url-shortener">URL Shortener</a>
        <a class="nav-link" href="/services/suggestion-tool">Caption Tool</a>
      </div>
      <div class="nav-group">
        <div class="sidebar-label">Account</div>
        <a class="nav-link" href="/dashboard">Dashboard</a>
        <a class="nav-link" href="/profile">Profile</a>
      </div>
    </aside>

    <main class="main">
      <header class="topbar">
        <div>
          <h1>Creator CRM</h1>
          <p>Invite collaborators to join your CreatorOS workspace and track pending invitations.</p>
        </div>
        <div class="profile-chip">
          <span class="avatar"><%= user.initials %></span>
          <span><%= user.name %></span>
        </div>
      </header>

      <% if (success) { %>
        <div class="success-box"><%= success %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert-box"><%= error %></div>
      <% } %>

      <div class="cards-grid">
        <section class="panel">
          <div class="panel-head">
            <div>
              <h2>Send a collaborator invite</h2>
              <p>Enter the email and a short note to invite someone to your CreatorOS workspace.</p>
            </div>
            <span class="badge">Invite feature</span>
          </div>
          <form action="/services/creator-crm/invite" method="POST">
            <div class="form-row">
              <input class="input" type="email" name="email" placeholder="Collaborator email" required />
              <input class="input" type="text" name="projectName" placeholder="Project or workspace name (optional)" />
            </div>
            <div class="form-row">
              <textarea class="textarea" name="message" placeholder="Personal message (optional)"></textarea>
            </div>
            <button class="primary-btn" type="submit">Send Invite</button>
          </form>
        </section>

        <section class="stats-panel">
          <div class="panel">
            <div class="panel-head">
              <h2>Pending invites</h2>
            </div>
            <p>Keep track of open collaborator invitations and resend if needed.</p>
          </div>
          <div class="panel">
            <div class="panel-head">
              <h2>Recent activity</h2>
            </div>
            <p>Invitation state updates automatically after acceptance.</p>
          </div>
        </section>
      </div>

      <section class="panel" style="margin-top: 1.5rem;">
        <div class="panel-head">
          <h2>Invitation history</h2>
          <span class="badge"><%= invites.length %> recent</span>
        </div>
        <% if (invites.length === 0) { %>
          <div class="info-box">No invitations have been sent yet. Use the form above to invite collaborators.</div>
        <% } else { %>
          <div style="overflow-x:auto;">
            <table class="table">
              <thead>
                <tr>
                  <th>Email</th>
                  <th>Project</th>
                  <th>Status</th>
                  <th>Sent</th>
                </tr>
              </thead>
              <tbody>
                <% invites.forEach(function(invite) { %>
                  <tr>
                    <td><%= invite.email %></td>
                    <td><%= invite.projectName %></td>
                    <td>
                      <span class="status-pill status-<%= invite.status %>"><%= invite.status %></span>
                    </td>
                    <td><%= new Date(invite.createdAt).toLocaleString() %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>
  </div>
</body>
</html>
